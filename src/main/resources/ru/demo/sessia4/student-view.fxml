<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox alignment="CENTER" spacing="20.0" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="ru.demo.sessia4.StudentController">
    <children>
        <GridPane prefHeight="374.0" prefWidth="750.0">
            <columnConstraints>
                <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0" />
            </columnConstraints>
            <rowConstraints>
                <RowConstraints maxHeight="236.0" minHeight="6.0" prefHeight="32.0" vgrow="SOMETIMES" />
                <RowConstraints maxHeight="304.0" minHeight="98.0" prefHeight="302.0" vgrow="SOMETIMES" />
                <RowConstraints vgrow="SOMETIMES" />
            </rowConstraints>
            <children>
                <HBox prefHeight="62.0" prefWidth="750.0">
                    <children>
                        <TextField fx:id="searchSpecialtyField" prefHeight="25.0" prefWidth="160.0" promptText="Поиск по шифру специальности">
                            <HBox.margin>
                                <Insets bottom="5.0" left="5.0" right="5.0" top="5.0" />
                            </HBox.margin>
                        </TextField>
                        <Label text="Год рождения">
                            <HBox.margin>
                                <Insets bottom="5.0" left="10.0" right="5.0" top="5.0" />
                            </HBox.margin>
                        </Label>
                        <TextField fx:id="yearFromField" prefHeight="25.0" prefWidth="70.0" promptText="от">
                            <HBox.margin>
                                <Insets bottom="5.0" left="5.0" right="5.0" top="5.0" />
                            </HBox.margin>
                        </TextField>
                        <Label text="по">
                            <HBox.margin>
                                <Insets bottom="5.0" left="5.0" right="5.0" top="5.0" />
                            </HBox.margin>
                        </Label>
                        <TextField fx:id="yearToField" prefHeight="25.0" prefWidth="70.0" promptText="до">
                            <HBox.margin>
                                <Insets bottom="5.0" left="5.0" right="5.0" top="5.0" />
                            </HBox.margin>
                        </TextField>
                        <ComboBox fx:id="sortComboBox" prefHeight="25.0" prefWidth="180.0" promptText="Сортировка по ФИО">
                            <HBox.margin>
                                <Insets bottom="5.0" left="10.0" right="5.0" top="5.0" />
                            </HBox.margin>
                        </ComboBox>
                    </children>
                </HBox>
                <TableView fx:id="tableView" prefHeight="0.0" prefWidth="750.0" GridPane.rowIndex="1">
                    <columns>
                        <TableColumn fx:id="numberpp" editable="false" prefWidth="80.0" text="Номер п/п" />
                        <TableColumn fx:id="specialtyCode" editable="false" prefWidth="130.0" text="Шифр специальности" />
                        <TableColumn fx:id="lastName" editable="false" prefWidth="150.0" text="Фамилия" />
                        <TableColumn fx:id="firstName" editable="false" prefWidth="100.0" text="Имя" />
                        <TableColumn fx:id="middleName" editable="false" prefWidth="120.0" text="Отчество" />
                        <TableColumn fx:id="birthYear" editable="false" prefWidth="120.0" text="Год рождения" />
                    </columns>
                    <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                    </columnResizePolicy>
                </TableView>
                <HBox prefHeight="0.0" prefWidth="750.0" GridPane.rowIndex="2">
                    <children>
                        <Button mnemonicParsing="false" onAction="#onAddClick" text="Добавить">
                            <HBox.margin>
                                <Insets bottom="5.0" left="5.0" right="5.0" top="5.0" />
                            </HBox.margin>
                        </Button>
                        <Button mnemonicParsing="false" onAction="#onRemoveClick" text="Удалить">
                            <HBox.margin>
                                <Insets bottom="5.0" left="5.0" right="5.0" top="5.0" />
                            </HBox.margin>
                        </Button>
                        <Button mnemonicParsing="false" onAction="#onUpdateClick" text="Изменить">
                            <HBox.margin>
                                <Insets bottom="5.0" left="5.0" right="5.0" top="5.0" />
                            </HBox.margin>
                        </Button>
                    </children>
                </HBox>
            </children>
        </GridPane>
    </children>
</VBox>